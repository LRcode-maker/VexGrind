<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Conventional and Unconventional Robots — VexGrind</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:wght@300;400;500&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #07090f;
      --bg2: #0d1220;
      --bg3: #111827;
      --accent: #AC2E44;
      --accent2: #e84560;
      --blue: #1e6dff;
      --text: #f0f2ff;
      --text2: #c8cde8;
      --muted: #7a82a0;
      --border: rgba(255,255,255,0.07);
      --card: rgba(255,255,255,0.04);
      --radius: 14px;
      --green: #4ade80;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      overflow-x: hidden;
    }

    /* ── PROGRESS BAR ── */
    #progress-bar {
      position: fixed;
      top: 0; left: 0;
      height: 3px;
      width: 0%;
      background: linear-gradient(90deg, var(--accent), var(--accent2), #ff8c60);
      z-index: 200;
      transition: width 0.1s linear;
    }

    /* ── NAV ── */
    nav {
      position: fixed; top: 3px; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1.1rem 3rem;
      background: rgba(7,9,15,0.75);
      backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border);
    }

    .nav-logo {
      font-family: 'Syne', sans-serif;
      font-weight: 800; font-size: 1.25rem;
      background: linear-gradient(135deg, #fff 40%, var(--accent2));
      -webkit-background-clip: text; background-clip: text;
      -webkit-text-fill-color: transparent; color: transparent;
      text-decoration: none;
    }

    .nav-links { display: flex; gap: 2rem; list-style: none; }
    .nav-links a { color: var(--muted); text-decoration: none; font-size: 0.9rem; transition: color 0.2s; }
    .nav-links a:hover, .nav-links a.active { color: var(--text); }

    .nav-actions { display: flex; gap: 1rem; align-items: center; }
    .btn-ghost { background: none; border: none; color: var(--muted); font-family: inherit; font-size: 0.9rem; cursor: pointer; transition: color 0.2s; }
    .btn-ghost:hover { color: var(--text); }
    .btn-primary { background: var(--accent); color: #fff; border: none; padding: 0.55rem 1.3rem; border-radius: 8px; font-family: inherit; font-size: 0.9rem; font-weight: 500; cursor: pointer; transition: background 0.2s, transform 0.15s; }
    .btn-primary:hover { background: var(--accent2); transform: translateY(-1px); }

    /* ── ARTICLE HERO ── */
    .article-hero {
      position: relative;
      min-height: 70vh;
      display: flex;
      align-items: flex-end;
      padding: 10rem 3rem 5rem;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute; inset: 0;
      background:
        radial-gradient(ellipse 70% 80% at 60% 30%, rgba(172,46,68,0.22) 0%, transparent 65%),
        radial-gradient(ellipse 40% 60% at 10% 80%, rgba(30,109,255,0.1) 0%, transparent 60%),
        linear-gradient(to bottom, rgba(7,9,15,0) 0%, rgba(7,9,15,0.95) 100%);
      z-index: 1;
    }

    .hero-grid {
      position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
      background-size: 60px 60px;
    }

    .hero-orb {
      position: absolute;
      top: 20%; left: 55%;
      width: 400px; height: 400px;
      border-radius: 50%;
      background: radial-gradient(circle at 40% 40%, rgba(172,46,68,0.4), rgba(30,109,255,0.15) 50%, transparent 75%);
      filter: blur(60px);
      animation: pulse 5s ease-in-out infinite;
    }

    .hero-icon-wrap {
      position: absolute;
      top: 50%; left: 60%;
      transform: translate(-50%, -60%);
      font-size: 9rem;
      filter: drop-shadow(0 0 60px rgba(172,46,68,0.5));
      animation: float 5s ease-in-out infinite;
      z-index: 1;
    }

    .hero-content {
      position: relative; z-index: 2;
      max-width: 720px;
    }

    .breadcrumb {
      display: flex; align-items: center; gap: 0.5rem;
      font-size: 0.78rem; color: var(--muted);
      margin-bottom: 1.5rem;
      animation: fadeUp 0.5s ease both;
    }
    .breadcrumb a { color: var(--muted); text-decoration: none; transition: color 0.2s; }
    .breadcrumb a:hover { color: var(--text); }
    .breadcrumb span { color: var(--border); }

    .article-tag {
      display: inline-flex; align-items: center; gap: 6px;
      background: rgba(172,46,68,0.15);
      border: 1px solid rgba(172,46,68,0.3);
      border-radius: 6px;
      padding: 0.3rem 0.8rem;
      font-size: 0.72rem; font-weight: 500;
      text-transform: uppercase; letter-spacing: 0.07em;
      color: var(--accent2);
      margin-bottom: 1.2rem;
      animation: fadeUp 0.5s 0.05s ease both;
    }

    .article-hero h1 {
      font-family: 'DM Serif Display', serif;
      font-size: clamp(2.4rem, 5vw, 4.2rem);
      font-weight: 400;
      line-height: 1.1;
      letter-spacing: -0.01em;
      margin-bottom: 1.25rem;
      animation: fadeUp 0.5s 0.1s ease both;
    }

    .article-hero h1 em {
      font-style: italic;
      color: var(--accent2);
    }

    .article-byline {
      display: flex; align-items: center; gap: 1rem;
      font-size: 0.85rem;
      animation: fadeUp 0.5s 0.15s ease both;
    }

    .byline-avatar {
      width: 42px; height: 42px; border-radius: 50%;
      background: linear-gradient(135deg, var(--accent), #ff8c60);
      display: flex; align-items: center; justify-content: center;
      font-family: 'Syne', sans-serif;
      font-size: 0.85rem; font-weight: 700;
      flex-shrink: 0;
    }

    .byline-name { font-weight: 500; }
    .byline-meta { color: var(--muted); font-size: 0.78rem; margin-top: 2px; }

    .byline-divider { width: 1px; height: 30px; background: var(--border); }

    .byline-stat { text-align: center; }
    .byline-stat-val { font-family: 'Syne', sans-serif; font-size: 0.95rem; font-weight: 700; }
    .byline-stat-label { color: var(--muted); font-size: 0.72rem; }

    /* ── ARTICLE LAYOUT ── */
    .article-layout {
      max-width: 1180px;
      margin: 0 auto;
      padding: 4rem 3rem 8rem;
      display: grid;
      grid-template-columns: 260px 1fr;
      gap: 5rem;
      align-items: start;
    }

    /* ── TOC SIDEBAR ── */
    .toc-sidebar {
      position: sticky;
      top: 100px;
    }

    .toc-label {
      font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.12em;
      color: var(--muted); margin-bottom: 1rem;
      font-weight: 500;
    }

    .toc-list { list-style: none; border-left: 1px solid var(--border); }
    .toc-item { position: relative; }

    .toc-link {
      display: block;
      padding: 0.45rem 1rem;
      font-size: 0.82rem; color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
      border-left: 2px solid transparent;
      margin-left: -1px;
    }
    .toc-link:hover { color: var(--text); }
    .toc-link.active {
      color: var(--accent2);
      border-left-color: var(--accent2);
    }

    .toc-divider { height: 1px; background: var(--border); margin: 1.5rem 0; }

    .share-label {
      font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.12em;
      color: var(--muted); margin-bottom: 0.75rem;
      font-weight: 500;
    }

    .share-btns { display: flex; flex-direction: column; gap: 0.5rem; }
    .share-btn {
      display: flex; align-items: center; gap: 0.65rem;
      padding: 0.55rem 0.9rem;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 8px;
      font-family: inherit; font-size: 0.8rem; color: var(--muted);
      cursor: pointer; transition: all 0.2s;
      text-align: left;
    }
    .share-btn:hover { border-color: rgba(255,255,255,0.15); color: var(--text); }

    .reading-box {
      margin-top: 1.5rem;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1rem;
    }
    .reading-box-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 0.5rem; }
    .reading-progress-track {
      height: 4px; background: rgba(255,255,255,0.06); border-radius: 2px; overflow: hidden;
      margin-bottom: 0.5rem;
    }
    .reading-progress-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--accent), var(--accent2));
      border-radius: 2px;
      width: 0%;
      transition: width 0.2s;
    }
    .reading-pct { font-family: 'Syne', sans-serif; font-size: 1rem; font-weight: 700; color: var(--accent2); }

    /* ── ARTICLE BODY ── */
    .article-body {
      min-width: 0;
    }

    /* Lead */
    .article-lead {
      font-family: 'DM Serif Display', serif;
      font-size: 1.35rem;
      line-height: 1.6;
      color: var(--text2);
      margin-bottom: 3rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid var(--border);
    }

    /* Sections */
    .article-section { margin-bottom: 3.5rem; }

    .section-anchor {
      display: block;
      position: relative;
      top: -120px;
      visibility: hidden;
    }

    .article-section h2 {
      font-family: 'Syne', sans-serif;
      font-size: 1.6rem; font-weight: 800;
      margin-bottom: 1.25rem;
      display: flex; align-items: center; gap: 0.75rem;
    }

    .section-num {
      font-size: 0.7rem;
      color: var(--accent2);
      background: rgba(172,46,68,0.12);
      border: 1px solid rgba(172,46,68,0.25);
      border-radius: 4px;
      padding: 0.2rem 0.5rem;
      font-family: 'DM Sans', sans-serif;
      font-weight: 500;
      letter-spacing: 0.05em;
    }

    .article-section h3 {
      font-family: 'Syne', sans-serif;
      font-size: 1.1rem; font-weight: 700;
      margin: 2rem 0 0.75rem;
      color: var(--text);
    }

    .article-section p {
      color: var(--text2);
      font-size: 1.01rem;
      line-height: 1.85;
      margin-bottom: 1.1rem;
    }

    /* Pull quote */
    .pull-quote {
      margin: 2.5rem 0;
      padding: 1.75rem 2rem;
      border-left: 3px solid var(--accent2);
      background: rgba(172,46,68,0.07);
      border-radius: 0 var(--radius) var(--radius) 0;
      font-family: 'DM Serif Display', serif;
      font-size: 1.2rem;
      line-height: 1.55;
      color: var(--text);
      font-style: italic;
    }

    /* Info box */
    .info-box {
      margin: 2rem 0;
      padding: 1.4rem 1.5rem;
      background: rgba(30,109,255,0.07);
      border: 1px solid rgba(30,109,255,0.2);
      border-radius: var(--radius);
    }
    .info-box-head {
      display: flex; align-items: center; gap: 0.6rem;
      font-family: 'Syne', sans-serif;
      font-size: 0.85rem; font-weight: 700;
      color: #60a5fa;
      margin-bottom: 0.6rem;
    }
    .info-box p { color: var(--muted); font-size: 0.88rem; line-height: 1.65; margin-bottom: 0; }

    /* Visual card */
    .visual-card {
      margin: 2.5rem 0;
      border-radius: var(--radius);
      overflow: hidden;
      border: 1px solid var(--border);
    }

    .visual-inner {
      min-height: 220px;
      display: flex; align-items: center; justify-content: center;
      gap: 3rem;
      padding: 2.5rem;
      position: relative;
      overflow: hidden;
    }

    .visual-inner::before {
      content: '';
      position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
      background-size: 40px 40px;
    }

    .vis-conventional {
      background: linear-gradient(135deg, rgba(30,109,255,0.2), rgba(7,9,15,0.9));
    }
    .vis-unconventional {
      background: linear-gradient(135deg, rgba(172,46,68,0.2), rgba(7,9,15,0.9));
    }

    .vis-item {
      text-align: center; position: relative; z-index: 1;
      flex: 1;
    }
    .vis-icon { font-size: 4rem; margin-bottom: 0.75rem; filter: drop-shadow(0 4px 20px rgba(0,0,0,0.4)); }
    .vis-title {
      font-family: 'Syne', sans-serif;
      font-size: 0.85rem; font-weight: 700;
      margin-bottom: 0.35rem;
    }
    .vis-desc { color: var(--muted); font-size: 0.78rem; line-height: 1.5; }

    .vis-divider {
      width: 1px; height: 120px;
      background: linear-gradient(to bottom, transparent, var(--border), transparent);
      flex-shrink: 0;
      position: relative; z-index: 1;
    }

    .visual-caption {
      background: var(--bg2);
      padding: 0.9rem 1.5rem;
      font-size: 0.78rem; color: var(--muted);
      text-align: center;
      border-top: 1px solid var(--border);
    }

    /* Comparison table */
    .compare-table {
      width: 100%;
      border-collapse: collapse;
      margin: 2rem 0;
      font-size: 0.88rem;
    }
    .compare-table th {
      font-family: 'Syne', sans-serif;
      font-size: 0.78rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.07em;
      padding: 0.8rem 1rem;
      text-align: left;
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }
    .compare-table th:first-child { color: var(--muted); }
    .compare-table th:nth-child(2) { color: #60a5fa; }
    .compare-table th:nth-child(3) { color: var(--accent2); }

    .compare-table td {
      padding: 0.8rem 1rem;
      border-bottom: 1px solid var(--border);
      color: var(--text2);
      vertical-align: top;
    }
    .compare-table tr:last-child td { border-bottom: none; }
    .compare-table tr:hover td { background: rgba(255,255,255,0.02); }
    .compare-table td:first-child { color: var(--muted); font-size: 0.8rem; font-weight: 500; }

    /* Key takeaway */
    .takeaway {
      margin: 3rem 0;
      padding: 2rem;
      background: linear-gradient(135deg, rgba(172,46,68,0.12), rgba(30,109,255,0.08));
      border: 1px solid rgba(172,46,68,0.2);
      border-radius: var(--radius);
    }
    .takeaway-head {
      font-family: 'Syne', sans-serif;
      font-size: 0.75rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.1em;
      color: var(--accent2);
      margin-bottom: 0.75rem;
    }
    .takeaway p { color: var(--text2); font-size: 0.93rem; line-height: 1.75; margin-bottom: 0; }

    /* Tag list / key terms */
    .key-terms { display: flex; flex-wrap: wrap; gap: 0.5rem; margin: 1.5rem 0; }
    .key-term {
      padding: 0.3rem 0.75rem;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 6px;
      font-size: 0.78rem; color: var(--muted);
    }

    /* ── DIVIDER ── */
    .art-divider {
      display: flex; align-items: center; gap: 1rem;
      margin: 3rem 0;
    }
    .art-divider::before, .art-divider::after { content: ''; flex: 1; height: 1px; background: var(--border); }
    .art-divider span { color: var(--accent2); font-size: 1rem; }

    /* ── AUTHOR BOX ── */
    .author-box {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.75rem;
      display: flex; gap: 1.5rem; align-items: flex-start;
      margin-top: 4rem;
    }
    .author-box-avatar {
      width: 60px; height: 60px; border-radius: 14px;
      background: linear-gradient(135deg, var(--accent), #ff8c60);
      display: flex; align-items: center; justify-content: center;
      font-family: 'Syne', sans-serif;
      font-size: 1.2rem; font-weight: 700;
      flex-shrink: 0;
    }
    .author-box-name {
      font-family: 'Syne', sans-serif;
      font-size: 1rem; font-weight: 700; margin-bottom: 0.25rem;
    }
    .author-box-role { color: var(--accent2); font-size: 0.78rem; margin-bottom: 0.6rem; }
    .author-box p { color: var(--muted); font-size: 0.85rem; line-height: 1.65; }

    /* ── MORE POSTS ── */
    .more-section {
      max-width: 1180px;
      margin: 0 auto;
      padding: 0 3rem 6rem;
    }

    .more-label {
      font-family: 'Syne', sans-serif;
      font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.12em;
      color: var(--muted); margin-bottom: 1.5rem;
    }

    .more-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.25rem;
    }

    .more-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      cursor: pointer;
      text-decoration: none;
      transition: border-color 0.3s, transform 0.3s;
      display: block;
    }
    .more-card:hover { border-color: rgba(172,46,68,0.4); transform: translateY(-4px); }

    .more-thumb {
      height: 120px;
      display: flex; align-items: center; justify-content: center;
      font-size: 2.5rem;
      position: relative; overflow: hidden;
    }
    .more-thumb::before {
      content: '';
      position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
      background-size: 30px 30px;
    }
    .more-thumb span { position: relative; z-index: 1; }
    .tb-build { background: linear-gradient(135deg, rgba(30,109,255,0.3), rgba(7,9,15,0.8)); }
    .tb-code  { background: linear-gradient(135deg, rgba(74,222,128,0.2), rgba(7,9,15,0.8)); }
    .tb-strat { background: linear-gradient(135deg, rgba(251,191,36,0.2), rgba(7,9,15,0.8)); }

    .more-body { padding: 1.1rem; }
    .more-tag { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); margin-bottom: 0.4rem; }
    .more-body h3 { font-family: 'Syne', sans-serif; font-size: 0.9rem; font-weight: 700; line-height: 1.3; color: var(--text); }

    /* ── FOOTER ── */
    footer {
      border-top: 1px solid var(--border);
      padding: 2rem 3rem;
      display: flex; align-items: center; justify-content: space-between;
      color: var(--muted); font-size: 0.82rem;
    }

    /* ── BACK BTN ── */
    .back-btn {
      display: inline-flex; align-items: center; gap: 0.5rem;
      color: var(--muted); text-decoration: none; font-size: 0.85rem;
      transition: color 0.2s;
      margin-bottom: 2rem;
    }
    .back-btn:hover { color: var(--text); }

    /* ── ANIMATIONS ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes float {
      0%, 100% { transform: translateY(0) rotate(-3deg); }
      50%       { transform: translateY(-18px) rotate(3deg); }
    }
    @keyframes pulse {
      0%, 100% { opacity: 0.5; transform: scale(1); }
      50%       { opacity: 0.9; transform: scale(1.08); }
    }

    /* ── REVEAL ── */
    .reveal {
      opacity: 0; transform: translateY(22px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      .article-layout { grid-template-columns: 1fr; gap: 2rem; }
      .toc-sidebar { display: none; }
      .more-grid { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 768px) {
      nav { padding: 1rem 1.5rem; }
      .nav-links { display: none; }
      .article-hero { padding: 8rem 1.5rem 4rem; min-height: auto; }
      .hero-icon-wrap { display: none; }
      .article-layout, .more-section { padding-left: 1.5rem; padding-right: 1.5rem; }
      .more-grid { grid-template-columns: 1fr; }
      footer { flex-direction: column; gap: 1rem; text-align: center; }
      .vis-unconventional .vis-item:not(:first-child) { display: none; }
      .vis-divider { display: none; }
    }
  </style>
</head>
<body>

<!-- READING PROGRESS -->
<div id="progress-bar"></div>

<!-- NAV -->
<nav>
  <a href="index.html" class="nav-logo">VexGrind</a>
  <ul class="nav-links">
    <li><a href="#">Guides</a></li>
    <li><a href="#">Robot Builds</a></li>
    <li><a href="blog.html" class="active">Blog</a></li>
    <li><a href="#">Community</a></li>
  </ul>
  <div class="nav-actions">
    <button class="btn-ghost">Sign in</button>
    <button class="btn-primary">Join the team →</button>
  </div>
</nav>

<!-- ARTICLE HERO -->
<section class="article-hero">
  <div class="hero-bg"></div>
  <div class="hero-grid"></div>
  <div class="hero-orb"></div>
  <div class="hero-icon-wrap">🤖</div>

  <div class="hero-content">
    <div class="breadcrumb">
      <a href="index.html">Home</a>
      <span>/</span>
      <a href="blog.html">Blog</a>
      <span>/</span>
      <span style="color:var(--text)">Conventional &amp; Unconventional Robots</span>
